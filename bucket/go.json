{
    "$schema": "https://raw.githubusercontent.com/ScoopInstaller/Scoop/master/schema.json",
    "version": "1.26.1",
    "description": "An open source programming language that makes it easy to build simple, reliable, and efficient software.",
    "homepage": "https://go.dev/",
    "license": {
        "identifier": "BSD-3-Clause",
        "url": "https://go.dev/LICENSE"
    },
    "architecture": {
        "64bit": {
            "url": "https://dl.google.com/go/go1.26.1.windows-amd64.zip",
            "hash": "9b68112c913f45b7aebbf13c036721264bbba7e03a642f8f7490c561eebd1ecc"
        },
        "32bit": {
            "url": "https://dl.google.com/go/go1.26.1.windows-386.zip",
            "hash": "6a26b7ce038d96d2b3457ea4933667fb85c896411860216daf6ea17ecd4b25c5"
        }
    },
    "extract_dir": "go",
    "env_add_path": "bin",
    "checkver": {
        "url": "https://golang.org/dl/",
        "regex": "go([\\d.]+)\\.windows-"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://dl.google.com/go/go$version.windows-amd64.zip"
            },
            "32bit": {
                "url": "https://dl.google.com/go/go$version.windows-386.zip"
            }
        },
        "hash": {
            "url": "$url.sha256"
        }
    }
}

    "architecture": {
        "64bit": {
            "url": "https://github.com/JanDeDobbeleer/aliae/releases/download/v1.1.1/aliae-windows-amd64.exe",
            "hash": "8bf3251e7c32bdb3a1d747609ae3e68b0ac312d0c7044fa7fd9b71f423771ef2"
        },
        "32bit": {
            "url": "https://github.com/JanDeDobbeleer/aliae/releases/download/v1.1.1/aliae-windows-386.exe",
            "hash": "ec3632cfada2abe0169a5cae5ab34e17f0e65d0c930a1011d3c95ef0653fa6f4"
        },
        "arm64": {
            "url": "https://github.com/JanDeDobbeleer/aliae/releases/download/v1.1.1/aliae-windows-arm64.exe",
            "hash": "e60693931831d9135c15b43ce9cffa113a37de4689cef410ad99215ab898074c"
        }
    },
    "pre_install": [
        "New-Item -ItemType Directory -Path \"$dir\\bin\" -Force | Out-Null",
        "Move-Item \"$dir\\aliae-windows-*.exe\" \"$dir\\bin\\aliae.exe\""
    ],
    "env_add_path": "bin",
    "checkver": {
        "github": "https://github.com/JanDeDobbeleer/aliae"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/JanDeDobbeleer/aliae/releases/download/v$version/aliae-windows-amd64.exe"
            },
            "32bit": {
                "url": "https://github.com/JanDeDobbeleer/aliae/releases/download/v$version/aliae-windows-386.exe"
            },
            "arm64": {
                "url": "https://github.com/JanDeDobbeleer/aliae/releases/download/v$version/aliae-windows-arm64.exe"
            }
        }
    }
}

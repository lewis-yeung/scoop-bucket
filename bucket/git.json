{
    "$schema": "https://raw.githubusercontent.com/ScoopInstaller/Scoop/master/schema.json",
    "version": "2.55.0",
    "description": "The Windows port of Git, a free and open source distributed version control system.",
    "homepage": "https://gitforwindows.org/",
    "license": {
        "identifier": "GPL-2.0-only",
        "url": "https://github.com/git-for-windows/git/blob/main/COPYING"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/git-for-windows/git/releases/download/v2.55.0.windows.1/PortableGit-2.55.0-64-bit.7z.exe#/dl.7z",
            "hash": "dfa8cad3ce7e685b9bfbbb2125afcf7c68d4f53490426702ffac367dac62e928"
        },
        "arm64": {
            "url": "https://github.com/git-for-windows/git/releases/download/v2.55.0.windows.1/PortableGit-2.55.0-arm64.7z.exe#/dl.7z",
            "hash": "b1fe421482c6e5a1aa1135406d7eeb89adf5436b3e5af183cdcd6ffe3c6bc8f2"
        }
    },
    "post_install": "& \"$dir\\bin\\bash.exe\" -c 'cmd //c /post-install.bat' *>$null",
    "env_add_path": "bin",
    "persist": [
        "etc\\fstab",
        "etc\\gitconfig"
    ],
    "checkver": {
        "url": "https://api.github.com/repos/git-for-windows/git/releases/latest",
        "jsonpath": "$.tag_name",
        "regex": "(?<tag>v([\\d.]+)\\.windows\\.\\d)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/git-for-windows/git/releases/download/$matchTag/PortableGit-$version-64-bit.7z.exe#/dl.7z"
            },
            "arm64": {
                "url": "https://github.com/git-for-windows/git/releases/download/$matchTag/PortableGit-$version-arm64.7z.exe#/dl.7z"
            }
        },
        "hash": {
            "url": "https://github.com/git-for-windows/git/releases/tag/$matchTag",
            "regex": "(?s)$basename.*?$sha256"
        }
    }
}

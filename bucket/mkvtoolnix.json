{
    "$schema": "https://raw.githubusercontent.com/ScoopInstaller/Scoop/master/schema.json",
    "version": "100.0",
    "description": "A set of tools to create, alter and inspect Matroska files.",
    "homepage": "https://mkvtoolnix.download/",
    "license": {
        "identifier": "GPL-2.0-or-later",
        "url": "https://gitlab.com/mbunkus/mkvtoolnix/-/blob/main/COPYING"
    },
    "architecture": {
        "64bit": {
            "url": "https://mkvtoolnix.download/windows/releases/100.0/mkvtoolnix-64-bit-100.0.7z",
            "hash": "sha512:fc8fca41767a892915b8dbec730f4ac396043bb1ab3c76192aee2d31426dce348da62b7fa2b8b8feea4955c0cacd850481c72a1d28e00263a78c2889a1becd7a"
        },
        "32bit": {
            "url": "https://mkvtoolnix.download/windows/releases/100.0/mkvtoolnix-32-bit-100.0.7z",
            "hash": "sha512:fdc35a896faabf7b70bcf6650f2d2afab248b711834f7bc27b1910b4b6ce1054c0d97167b5020e33c734164c0d3e16741017bfc2f69472383d3d99f617d4777a"
        }
    },
    "extract_dir": "mkvtoolnix",
    "pre_install": [
        "if (Test-Path \"$persist_dir\\mkvtoolnix-gui.ini\") {",
        "  # Persist 'mkvtoolnix-gui.ini' manully because a hard link doesn't work.",
        "  Copy-Item \"$persist_dir\\mkvtoolnix-gui.ini\" \"$dir\\\"",
        "} else {",
        "  Set-Content -Encoding Ascii -Path \"$dir\\mkvtoolnix-gui.ini\" -Value @(",
        "    '[settings]'",
        "    'updates\\checkForUpdates=false'",
        "  )",
        "}"
    ],
    "pre_uninstall": [
        "if (!(Test-Path \"$persist_dir\")) {",
        "  New-Item -ItemType Directory -Path \"$persist_dir\" -Force | Out-Null",
        "}",
        "Copy-Item \"$dir\\mkvtoolnix-gui.ini\" \"$persist_dir\\\" -ErrorAction SilentlyContinue -Force"
    ],
    "shortcuts": [
        [
            "mkvtoolnix-gui.exe",
            "MKVToolNix GUI"
        ]
    ],
    "persist": [
        "cache",
        "jobQueue"
    ],
    "checkver": {
        "url": "https://mkvtoolnix.download/doc/NEWS.md",
        "regex": "# Version ([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://mkvtoolnix.download/windows/releases/$version/mkvtoolnix-64-bit-$version.7z"
            },
            "32bit": {
                "url": "https://mkvtoolnix.download/windows/releases/$version/mkvtoolnix-32-bit-$version.7z"
            }
        },
        "hash": {
            "url": "$baseurl/sha512sums.txt"
        }
    }
}

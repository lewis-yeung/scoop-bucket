    "version": "1.122.0",
    "description": "A lightweight but powerful source code editor.",
    "homepage": "https://code.visualstudio.com/",
    "license": {
        "identifier": "Proprietary,MIT",
        "url": "https://code.visualstudio.com/License"
    },
    "architecture": {
        "64bit": {
            "url": "https://update.code.visualstudio.com/1.122.0/win32-x64-archive/stable#/dl.7z",
            "hash": "78eacd0c1cc6aaaa6282f2e25bee5caceaebca25ef545ddd3f5098704b048b57"
        },
        "arm64": {
            "url": "https://update.code.visualstudio.com/1.122.0/win32-arm64-archive/stable#/dl.7z",
            "hash": "836af0812a5085e7391b87036a9edffc22cf4664cd7504e4a69c0721d2d2a0ab"
        }
    },
    "env_add_path": "bin",
    "shortcuts": [

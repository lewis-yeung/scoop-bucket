{
    "$schema": "https://raw.githubusercontent.com/ScoopInstaller/Scoop/master/schema.json",
    "version": "1.119.1",
    "description": "A lightweight but powerful source code editor.",
    "homepage": "https://code.visualstudio.com/",
    "license": {
        "identifier": "Proprietary,MIT",
        "url": "https://code.visualstudio.com/License"
    },
    "architecture": {
        "64bit": {
            "url": "https://update.code.visualstudio.com/1.119.1/win32-x64-archive/stable#/dl.7z",
            "hash": "6fd3396113d865571811497949a6c01784102e24f076e95a207d66918475894b"
        },
        "arm64": {
            "url": "https://update.code.visualstudio.com/1.119.1/win32-arm64-archive/stable#/dl.7z",
            "hash": "6438dc885a99b82fe72a5841f5caf7a321e689852c85bc087ff4eafd579d6ff5"
        }
    },
    "env_add_path": "bin",
    "shortcuts": [
        [
            "code.exe",
            "Visual Studio Code"
        ]
    ],
    "checkver": {
        "url": "https://update.code.visualstudio.com/api/update/win32-x64-archive/stable/latest",
        "regex": "\"name\":\\s*\"([\\d.]+)\""
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://update.code.visualstudio.com/$version/win32-x64-archive/stable#/dl.7z",
                "hash": {
                    "url": "https://update.code.visualstudio.com/api/update/win32-x64-archive/stable/latest",
                    "regex": "\"sha256hash\":\\s*\"$sha256\""
                }
            },
            "arm64": {
                "url": "https://update.code.visualstudio.com/$version/win32-arm64-archive/stable#/dl.7z",
                "hash": {
                    "url": "https://update.code.visualstudio.com/api/update/win32-arm64-archive/stable/latest",
                    "regex": "\"sha256hash\":\\s*\"$sha256\""
                }
            }
        }
    }
}

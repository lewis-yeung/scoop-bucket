{
    "$schema": "https://raw.githubusercontent.com/ScoopInstaller/Scoop/master/schema.json",
    "version": "1.17.8",
    "description": "A sandbox-based isolation software for Windows NT-based operating systems.",
    "homepage": "https://sandboxie-plus.com/",
    "license": {
        "identifier": "GPL-3.0-only",
        "url": "https://github.com/sandboxie-plus/Sandboxie/blob/master/LICENSE.Classic"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/sandboxie-plus/Sandboxie/releases/download/v1.17.8/Sandboxie-Plus-x64-v1.17.8.exe",
            "hash": "a72f94368c95b9d03adddc99963ccd04a68e85eb1f6b139a70e3c536ad4495af"
        },
        "arm64": {
            "url": "https://github.com/sandboxie-plus/Sandboxie/releases/download/v1.17.8/Sandboxie-Plus-ARM64-v1.17.8.exe",
            "hash": "9d845b6d1e7fff9fd82dfdb00b3a90d060ef427638179e9225c82876b9b1ef64"
        }
    },
    "innosetup": true,
    "pre_install": [
        "ensure \"$persist_dir\" | Out-Null",
        "Get-ChildItem \"$persist_dir/*.ini\" | Copy-Item -Destination \"$dir\" -Force -ErrorAction SilentlyContinue"
    ],
    "shortcuts": [
        [
            "SandMan.exe",
            "Sandboxie Plus"
        ]
    ],
    "pre_uninstall": [
        "Get-ChildItem \"$dir/*\" -Include @(",
        "  'Sandboxie.ini'",
        "  'Sandboxie-Plus.ini'",
        ") | Copy-Item -Destination \"$persist_dir\" -Force -ErrorAction SilentlyContinue"
    ],
    "checkver": {
        "github": "https://github.com/sandboxie-plus/Sandboxie"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/sandboxie-plus/Sandboxie/releases/download/v$version/Sandboxie-Plus-x64-v$version.exe"
            },
            "arm64": {
                "url": "https://github.com/sandboxie-plus/Sandboxie/releases/download/v$version/Sandboxie-Plus-ARM64-v$version.exe"
            }
        }
    }
}

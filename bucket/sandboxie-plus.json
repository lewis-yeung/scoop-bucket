            "hash": "14f2066a62c3f2952a3cdceffa8446e8c20d1f425d53ab86a19e52c99e282ed0"
        },
        "arm64": {
            "url": "https://github.com/sandboxie-plus/Sandboxie/releases/download/v1.17.7/Sandboxie-Plus-ARM64-v1.17.7.exe",
